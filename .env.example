# Bybit API Credentials
# IMPORTANT: Use your main account API keys for the leverage setting script to work correctly.
# Create these at https://www.bybit.com/app/user/api-management
BYBIT_API_KEY="YOUR_BYBIT_API_KEY"
BYBIT_API_SECRET="YOUR_BYBIT_API_SECRET"

# Binance API Credentials
# Used by the Real-Time Risk Manager for supplementary candle data.
# Create these at https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY="YOUR_BINANCE_API_KEY"
BINANCE_API_SECRET="YOUR_BINANCE_API_SECRET"

# Trading Parameters
# The minimum Risk-to-Reward Ratio required to execute a trade.
MIN_RISK_REWARD="1.2"
